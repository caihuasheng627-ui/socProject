# SkinVision AI 后端环境变量(复制为 .env 后填写)
# cp .env.example .env

# DeepSeek / 通义兼容 LLM(默认走阿里云百炼上的 DeepSeek)
# 与 Embedding 共用 DASHSCOPE_API_KEY 即可;也可单独填 DEEPSEEK_API_KEY
# 官方 DeepSeek 则改 BASE_URL=https://api.deepseek.com 与 MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_MODEL=deepseek-v3

# 阿里云百炼 DashScope(RAG Embedding + 可选 LLM)
# 控制台申请: https://bailian.console.aliyun.com/ → API-KEY
# 无 Key 时 RAG 自动降级关键词检索;LLM 无 Key 则 Mock
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_EMBED_MODEL=text-embedding-v3
RAG_EMBED_DIM=1024
RAG_USE_VECTOR=1

# 预测缓存有效期(小时)
PRED_CACHE_TTL_HOURS=6

# 展示货币:与训练数据同口径 USD
# 采集脚本(ml/data/scraper)将 BUFF CNY 价换算为 USD 时也会读取此键
USD_CNY_RATE=7.2

# BUFF 实时爬虫(默认关:课程演示用已落库历史价 + 训练 CSV 兜底,见策划书 §13.2)
USE_BUFF_LIVE=0
# 多平台 CLI 采集(ml/data/scraper/fetch_live_prices.py)用的 BUFF session Cookie
# 登录 buff.163.com → F12 → Application → Cookies → session
BUFF_SESSION=

# 增量训练调度(默认禁用;开 1 后每日调组员 2 的 --mode incremental 脚本)
ENABLE_INCREMENTAL_TRAIN=0

# JWT 认证(注册/登录);留空则用代码内默认值(仅本地演示用,生产务必改)
JWT_SECRET=
JWT_EXPIRE_DAYS=7
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123

# 管理员账号(启动时自动创建; 默认把 demo 也提权方便演示)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PROMOTE_DEMO=1
