# SkinVision AI 后端环境变量(复制为 .env 后填写)
# cp .env.example .env

# DeepSeek API Key(组员 3 的 /api/chat、辩论现场模式、RAG、组合诊断汇总都需要)
# 无 Key 时上述端点自动降级 Mock/预录回放,服务仍可起。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 预测缓存有效期(小时)
PRED_CACHE_TTL_HOURS=6

# 演示汇率(训练数据为 USD,前端展示 CNY)
USD_CNY_RATE=7.2

# BUFF 实时爬虫(默认关:课程演示用已落库历史价 + 训练 CSV 兜底,见策划书 §13.2)
USE_BUFF_LIVE=0

# 增量训练调度(默认禁用;开 1 后每日调组员 2 的 --mode incremental 脚本)
ENABLE_INCREMENTAL_TRAIN=0
